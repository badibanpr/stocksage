# Neon Postgres — add via Vercel dashboard (Storage → Create Database → Neon)
# Vercel auto-injects these when you connect a Neon database to your project
DATABASE_URL=
POSTGRES_URL=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Financial Modeling Prep
FMP_API_KEY=your-fmp-key

# Finnhub
FINNHUB_API_KEY=your-finnhub-key

# FRED (Federal Reserve Economic Data) — optional
FRED_API_KEY=your-fred-key

# App URL (used for internal refresh endpoint)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron secret — generate a random string, add as Vercel env var
CRON_SECRET=your-random-secret
